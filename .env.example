# LLM 提供商配置 (openai / ollama)
LLM_PROVIDER=ollama

# OpenAI API 配置 (当 LLM_PROVIDER=openai 时使用)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# 模型配置
# 当 LLM_PROVIDER=ollama 时: llama3, llama2, mistral, qwen 等
# 当 LLM_PROVIDER=openai 时: gpt-3.5-turbo, gpt-4 等
LLM_MODEL=llama3
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Embedding 模型配置
# 当 LLM_PROVIDER=ollama 时: nomic-embed-text
# 当 LLM_PROVIDER=openai 时: text-embedding-ada-002
EMBEDDING_MODEL=nomic-embed-text

# 向量数据库配置
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=knowledge_base
DEFAULT_TOP_K=4

# 检索配置
SEARCH_TYPE=hybrid
VECTOR_K=5
BM25_K=5
RERANK_TOP_N=3
USE_RERANKER=false

# 服务配置
HOST=0.0.0.0
PORT=8000
RELOAD=true
UPLOAD_DIR=./data
